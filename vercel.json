{
  "version": 2,
  "installCommand": "npm install --include=dev",
  "buildCommand": "npx vite build && node --input-type=module -e \"import{copyFileSync}from'fs';copyFileSync('dist/index.html','dist/404.html')\"",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
