# ============================================================
# Stableford+ — Vercel Environment Variables
# ============================================================
# Copy these into: Vercel Dashboard → Project → Settings → Environment Variables

# ---------------------------
# Database (Supabase)
# ---------------------------
# Get from: Supabase → Project Settings → Database → Connection string → URI
# IMPORTANT: append ?sslmode=require to the connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# ---------------------------
# Auth
# ---------------------------
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-strong-random-secret-here

# ---------------------------
# Stripe
# ---------------------------
# Get from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------
# App URL (for Stripe redirects)
# ---------------------------
# Your Vercel deployment URL (no trailing slash)
# e.g. https://stablefordplus.vercel.app  or your custom domain
APP_URL=https://your-app.vercel.app
